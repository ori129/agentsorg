# !! IMPORTANT: Copy this file to .env — do NOT commit .env or share it.
# Each developer must have their own .env with a unique FERNET_KEY.

# Fernet encryption key — used to encrypt API keys at rest in the database.
# Generate a unique key per developer/environment: make fernet-key
# NEVER share or reuse this key across environments.
FERNET_KEY=

# Optional overrides (defaults work out of the box with Docker Compose)
# POSTGRES_USER=agentsorg
# POSTGRES_PASSWORD=changeme
# POSTGRES_DB=agentsorg
# DATABASE_URL=postgresql+asyncpg://agentsorg:changeme@postgres:5432/agentsorg
# BACKEND_CORS_ORIGINS=http://localhost:3000

# To fully wipe your local database and start fresh: make fresh
