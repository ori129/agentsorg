# Fernet encryption key — used to encrypt API keys at rest in the database.
# Generate one by running:  make fernet-key
# Then paste the output below.
FERNET_KEY=

# Optional overrides (defaults work out of the box with Docker Compose)
# POSTGRES_USER=gpt_registry
# POSTGRES_PASSWORD=changeme
# POSTGRES_DB=gpt_registry
# DATABASE_URL=postgresql+asyncpg://gpt_registry:changeme@postgres:5432/gpt_registry
# BACKEND_CORS_ORIGINS=http://localhost:3000
